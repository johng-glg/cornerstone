# Cornerstone environment template.
# Copy to `.env` and fill in. NEVER commit a real `.env` (see .gitignore).
# The Lovable build committed live keys; this build keeps all secrets out of source.

# --- Frontend (Vite, exposed to the browser — publishable values only) ---
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=your-local-anon-key

# --- Edge functions / server-side (NOT exposed to the browser) ---
# These are set as Supabase function secrets / environment secrets, not in the FE build.
# Listed here for completeness; populated per environment via the secret manager.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Integration credentials (per-environment secrets; see docs/lovable_pattern_inventory.md §4):
# FORTH_CLIENT_ID=
# FORTH_API_KEY=
# DOCUSEAL_API_TOKEN=
# DOCUSEAL_WEBHOOK_SECRET=
# DIALPAD_API_TOKEN=
# DIALPAD_WEBHOOK_SECRET=
# DIALPAD_DEFAULT_USER_ID=
